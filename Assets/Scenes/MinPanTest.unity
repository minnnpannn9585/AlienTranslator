  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Peace holds between the two worlds, and cooperation settles in.  At shared
    stations, people line up together, trading what they\u2019ve brought. Somewhere
    in the crowd, the two leaders move side by side \u2014 newly married, still adjusting,
    arguing over nothing and laughing a moment later \u2014 and no one seems to mind.\nYou\u2019re
    officially named Chief Honorary Translator of Two Worlds, complete with medals,
    ceremonies, and a frankly ridiculous number of perks. You don\u2019t translate
    personally anymore \u2014 just open your door and there they are, a whole crowd
    from both planets, mumbling, gesturing, crowding in and elbowing for a chance
    to be your student."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8fd121633c2e20d469f9ca214aa2f9fd, type: 2}
  m_sharedMaterial: {fileID: 535832667782159134, guid: 8fd121633c2e20d469f9ca214aa2f9fd, type: 2}
